FROM docker.repo-cd1.sfera.test.vtb.ru/pim_cpnok-ml-docker-distr/astra:1.8-py3.11 AS base

USER 0

RUN mkdir -p /app/data/raw_data /app/data/prepared_data /tmp/lo-userprofile && \
    chmod -R 777 /app/data/raw_data /app/data/prepared_data /tmp/lo-userprofile /app

ARG username
ARG password
ARG username_encoded
ARG password_encoded
ARG project
ARG image

WORKDIR /app
COPY . .

RUN echo "deb http://mirror1.region.vtb.ru/stages_astra/1.8.1/repository-extended/ 1.8_x86-64 main contrib non-free" > /etc/apt/sources.list
RUN echo "deb http://mirror1.region.vtb.ru/stages_astra/1.8.1/repository-main/ 1.8_x86-64 main contrib non-free" >> /etc/apt/sources.list
RUN echo "Acquire::http::mirror1.region.vtb.ru::Verify-Peer \"false\";" > /etc/apt/apt.conf.d/99-verify-peer.conf

# --- Установка системных зависимостей ----------------
# default-jdk-headless устанавливает JDK 17
RUN apt update && apt install -y --allow-downgrades \
    # Java runtime (требуется для определенных функций LibreOffice)
    default-jdk-headless \
    # Системные утилиты
    systemd-timesyncd \
    libparse-base3=3.9+ci132 \
    libsystemd0=252.17-1~deb12u1astra.sel+ci13+b1 \
    libparse-aud3 \
    libudev1=252.17-1~deb12u1astra.sel+ci13+b1 \
    libssl-dev \
    pkg-config \
    udev \
    polkitd \
    # LibreOffice и компоненты для работы с DOC/XLS
    libreoffice \
    libreoffice-writer \
    libreoffice-calc \
    xvfb \
    # Интеграция с KDE (может потребоваться в Astra)
    #Libreoffice-kf5 \
    # Критические зависимости для headless-режима
    libx11-6 libxext6 libxrender1 libxt6 libgl1 libsm6 libice6 libxinerama1 libfontconfig1 libdbus-1-3 \
    # Qt платформа
    libxcb-xinerama0 libxcb-icccm4 libxcb-image0 libxcb-keysyms1 \
    libxcb-randr0 libxcb-render-util0 libxcb-shape0 libxcb-xfixes0 \
    libxcb-xkb1 libxkbcommon-x11-0 libxcb-cursor0 \
    # Шрифты
    fonts-dejavu fonts-dejavu-core fonts-liberation fonts-freefont-ttf \
    fontconfig libglib2.0-0 libnss3 libgtk-3-0 libx11-xcb1 libxcb1 libxcb-render0 libxcb-shm0 libxkbcommon0 \
    # Утилиты для отладки
    curl \
    && apt clean && rm -rf /var/lib/apt/lists/*

# Проверка установки (не прервёт сборку при ошибке)
RUN libreoffice --version || true
RUN java -version || true

RUN python -m pip install uv==0.9.3 \
    --trusted-host=misc.repo-cd1.sfera.test.vtb.ru \
    --extra-index-url https://${username_encoded}:${password_encoded}@misc.repo-cd1.sfera.test.vtb.ru/repository/pim_cpnok-ml-pypi/simple \
    --index-url https://${username_encoded}:${password_encoded}@misc.repo-cd1.sfera.test.vtb.ru/repository/pim_cpnok-ml-pypi-proxy-group/simple

RUN --mount=type=secret,id=netrc,dst=/root/.netrc uv sync --no-cache --no-dev

ENV HOME=/tmp \
    LIBREOFFICE_PATH=/usr/bin/libreoffice \
    RAW_DATA_DIR=/app/data/raw_data \
    PREPARED_DATA_DIR=/app/data/prepared_data \
    DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    # XDG настройки
    XDG_RUNTIME_DIR=/tmp

USER nobody

CMD ["uv", "run", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]